# Always write exact versions to package.json (no ^ or ~ ranges)
save-exact=true

# Block install/lifecycle scripts (postinstall etc.) — a common supply-chain
# vector. None of this project's deps require install scripts. If a future
# dependency genuinely needs one, allowlist it explicitly rather than removing this.
ignore-scripts=true

# Fail the install if engine requirements in package.json aren't met
engine-strict=true

# Reproducible installs: error if the lockfile would need to change
# (use `npm ci` in CI/deploy, which enforces this regardless)
